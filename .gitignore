# =============================================================================
#  Navya Computech — .gitignore
#  See https://help.github.com/articles/ignoring-files/
# =============================================================================

# -----------------------------------------------------------------------------
#  Secrets  ⚠ NEVER commit these — .env holds the MongoDB password, admin
#  password and auth secret. `.env.example` IS committed as the template.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# Certificates / keys
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
#  Site data  — JSON files written by the app (courses, queries, activity).
#  Queries/activity contain visitors' personal details, so keep them out of
#  git. courses.json IS committed — it's the catalogue the live site serves
#  (deploys can't write to disk, so the pushed file is the source of truth).
#  /public/uploads holds admin-uploaded course images and documents; commit
#  them so they survive on the live site too.
# -----------------------------------------------------------------------------
/data/inquiries.json
/data/activity.json
/data/*.tmp

# -----------------------------------------------------------------------------
#  Dependencies
# -----------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.yarn-integrity

# -----------------------------------------------------------------------------
#  Next.js build output
# -----------------------------------------------------------------------------
/.next/
/out/
/build
/dist
.swc/
.turbo/

# -----------------------------------------------------------------------------
#  TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
#  Testing / coverage
# -----------------------------------------------------------------------------
/coverage
*.lcov
.nyc_output

# -----------------------------------------------------------------------------
#  Logs & debug
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
report.*.json

# -----------------------------------------------------------------------------
#  Caches
# -----------------------------------------------------------------------------
.eslintcache
.stylelintcache
.cache/
.parcel-cache
.npm

# -----------------------------------------------------------------------------
#  Deployment
# -----------------------------------------------------------------------------
.vercel
.netlify

# -----------------------------------------------------------------------------
#  Editors / IDEs
# -----------------------------------------------------------------------------
.idea/
*.swp
*.swo
*~

# VS Code — ignore personal settings, but allow shared project config if added
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json

# -----------------------------------------------------------------------------
#  Operating system files
# -----------------------------------------------------------------------------
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/
*.stackdump
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
.directory
.Trash-*

# -----------------------------------------------------------------------------
#  Misc / temp
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.orig
