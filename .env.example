# Copy to `.env` and fill in. The site runs in demo mode until MONGODB_URI is set.

# --- MongoDB -----------------------------------------------------------------
# Option A — local MongoDB, browsed with MongoDB Compass (no signup):
MONGODB_URI=mongodb://localhost:27017
# Option B — MongoDB Atlas (cloud, needed for Vercel):
# MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=navya_computech

# --- Admin login for /admin (set all three to enable the login gate) ---------
ADMIN_EMAIL=admin@navyacomputech.com
ADMIN_PASSWORD=change-this-to-a-long-password
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-random-64-char-hex-string

# --- Optional — your production domain, used for SEO ------------------------
NEXT_PUBLIC_SITE_URL=
