# Copy to `.env` and fill in. The site runs in demo mode (local JSON files,
# sample catalogue) until the Supabase variables are set. A deployed site
# REQUIRES Supabase — serverless filesystems are read-only, so admin edits
# don't persist without it. Full setup guide: SUPABASE.md

# --- Supabase (Dashboard → Project Settings → API Keys) ----------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses Row Level Security. Never expose in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin login for /admin (set all three to enable the login gate) ---------
ADMIN_EMAIL=admin@navyacomputech.com
ADMIN_PASSWORD=change-this-to-a-long-password
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-a-random-64-char-hex-string

# --- Optional — your production domain, used for SEO ------------------------
NEXT_PUBLIC_SITE_URL=

# --- AI Chatbot (Optional — providing key enables online LLM models) ---------
# Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=
# OpenAI API key from https://platform.openai.com/
OPENAI_API_KEY=

